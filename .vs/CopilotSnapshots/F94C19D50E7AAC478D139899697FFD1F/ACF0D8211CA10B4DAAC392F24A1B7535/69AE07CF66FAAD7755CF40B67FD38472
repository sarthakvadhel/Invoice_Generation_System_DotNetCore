@page "/customers"

@inject CustomerService CustomerService

<PageTitle>Customers</PageTitle>

<h1>Customers</h1>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header">Add customer</div>
            <div class="card-body">
                <EditForm Model="_newCustomer" OnValidSubmit="AddCustomer" FormName="add-customer">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_newCustomer.Name" />
                        <ValidationMessage For="() => _newCustomer.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="_newCustomer.Email" />
                        <ValidationMessage For="() => _newCustomer.Email" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="_newCustomer.Phone" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <InputText class="form-control" @bind-Value="_newCustomer.Address" />
                    </div>

                    <button type="submit" class="btn btn-primary">Save</button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">Customer list</div>
            <div class="card-body">
                @if (_customers.Count == 0)
                {
                    <div class="text-muted">No customers yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in _customers)
                                {
                                    <tr>
                                        <td>@c.Name</td>
                                        <td>@c.Email</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCustomer(c.Id)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly Customer _newCustomer = new();
    private List<Customer> _customers = new();
    private string? _error;

    protected override void OnInitialized()
    {
        Refresh();
    }

    private void Refresh()
    {
        _customers = CustomerService.GetAll().ToList();
    }

    private void SaveCustomer()
    {
        _error = null;

        try
        {
            if (_isEditMode)
            {
                if (!CustomerService.Update(new Customer
                    {
                        Id = _editingId,
                        Name = _model.Name,
                        Email = _model.Email,
                        Phone = _model.Phone,
                        Address = _model.Address,
                    }))
                {
                    _error = "Unable to update customer.";
                    return;
                }
            }
            else
            {
                CustomerService.Add(new Customer
                {
                    Name = _model.Name,
                    Email = _model.Email,
                    Phone = _model.Phone,
                    Address = _model.Address,
                });
            }

            ResetForm();

            Refresh();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void DeleteCustomer(int id)
    {
        _error = null;

        if (!CustomerService.Delete(id))
        {
            _error = "Unable to delete customer. Delete their invoices first.";
            return;
        }

        Refresh();
    }

    private void BeginEdit(int id)
    {
        var customer = _customers.FirstOrDefault(c => c.Id == id);
        if (customer is null)
        {
            return;
        }

        _isEditMode = true;
        _editingId = customer.Id;
        _model = new Customer
        {
            Name = customer.Name,
            Email = customer.Email,
            Phone = customer.Phone,
            Address = customer.Address,
        };
    }

    private void CancelEdit()
    {
        ResetForm();
    }

    private void ResetForm()
    {
        _isEditMode = false;
        _editingId = 0;
        _model = new Customer();
    }
}
