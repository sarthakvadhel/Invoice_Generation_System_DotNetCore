@media (min-width: 901px) {
    .sidebar-toggle:checked ~ .sidebar-shell {
        width: 78px;
        overflow: hidden;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    .sidebar-toggle:checked ~ .sidebar-shell .brand-link,
    .sidebar-toggle:checked ~ .sidebar-shell .menu-text {
        display: none;
    }

    .sidebar-toggle:checked ~ .sidebar-shell .sidebar-header,
    .sidebar-toggle:checked ~ .sidebar-shell .menu-link {
        justify-content: center;
    }

    .sidebar-toggle:checked ~ .sidebar-shell .menu-link {
        gap: 0;
    }
}

@media (max-width: 900px) {
    .app-sidebar {
        width: 100%;
        min-height: auto;
        flex: 0 0 auto;
    }

    .sidebar-shell {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: 260px;
        transform: translateX(-100%);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        box-shadow: 0 0 0 9999px rgba(2, 6, 23, 0);
    }

    .sidebar-toggle:checked ~ .sidebar-shell {
        transform: translateX(0);
        box-shadow: 0 0 0 9999px rgba(2, 6, 23, 0.45);
    }

    .toggle-button {
        position: fixed;
        top: 0.9rem;
        left: 0.9rem;
        z-index: 40;
        background-color: #111827;
    }

    .sidebar-toggle:checked ~ .sidebar-shell .toggle-button {
        position: static;
        background-color: rgba(255, 255, 255, 0.12);
    }
}
