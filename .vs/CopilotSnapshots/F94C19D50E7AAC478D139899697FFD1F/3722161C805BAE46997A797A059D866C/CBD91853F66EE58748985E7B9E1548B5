.app-sidebar {
    position: relative;
    width: 280px;
    min-height: 100vh;
    flex: 0 0 280px;
    z-index: 20;
}

.sidebar-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
}

.sidebar-shell {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 1rem 0.75rem;
    background: linear-gradient(180deg, #111827 0%, #0f172a 100%);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: width 0.25s ease;
}

.sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.25rem 0.35rem 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.brand-link {
    color: #ffffff;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.015em;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
}

.brand-logo-img {
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.35);
    object-fit: cover;
    flex: 0 0 1.9rem;
}

.toggle-button {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    background-color: rgba(255, 255, 255, 0.08);
}

.menu-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.2rem;
}

.menu-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #dbe4f5;
    text-decoration: none;
    padding: 0.72rem 0.72rem;
    border-radius: 0.65rem;
    font-weight: 500;
    transition: background-color 0.2s ease, color 0.2s ease;
}

.menu-link:hover {
    color: #fff;
    background-color: rgba(59, 130, 246, 0.22);
}

.menu-link.active {
    color: #fff;
    background: linear-gradient(90deg, rgba(37, 99, 235, 0.35), rgba(59, 130, 246, 0.2));
    border: 1px solid rgba(147, 197, 253, 0.35);
}

.menu-text {
    white-space: nowrap;
}

.menu-icon {
    width: 1.15rem;
    height: 1.15rem;
    display: inline-block;
    background-size: 1.15rem 1.15rem;
    background-repeat: no-repeat;
    background-position: center;
    filter: brightness(0) invert(1);
    opacity: 0.95;
    flex: 0 0 1.15rem;
}

