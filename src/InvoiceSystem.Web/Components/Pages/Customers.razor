@page "/customers"

@inject CustomerService CustomerService

<PageTitle>Customers</PageTitle>

<h1>Customers</h1>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger" role="alert">@_error</div>
}

<div class="d-flex flex-column gap-4">
    <div class="card shadow-sm form-card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>@(_isEditMode ? "Edit customer" : "Add customer")</span>
            @if (_isEditMode)
            {
                <button type="button" class="btn btn-sm btn-light" @onclick="CancelEdit">Cancel</button>
            }
        </div>
        <div class="card-body">
            <EditForm Model="_model" OnValidSubmit="SaveCustomer" FormName="save-customer">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="_model.Name" />
                        <ValidationMessage For="() => _model.Name" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="_model.Email" />
                        <ValidationMessage For="() => _model.Email" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Phone</label>
                        <InputText class="form-control" @bind-Value="_model.Phone" />
                    </div>

                    <div class="col-12 col-md-6">
                        <label class="form-label">Address</label>
                        <InputText class="form-control" @bind-Value="_model.Address" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary mt-3">@(_isEditMode ? "Update customer" : "Save customer")</button>
            </EditForm>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Customer records</div>
        <div class="card-body">
            @if (_customers.Count == 0)
            {
                <div class="text-muted">No customers yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _customers)
                            {
                                <tr>
                                    <td>@c.Name</td>
                                    <td>@c.Email</td>
                                    <td>@c.Phone</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => BeginEdit(c.Id)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCustomer(c.Id)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private Customer _model = new();
    private List<Customer> _customers = new();
    private string? _error;
    private bool _isEditMode;
    private int _editingId;

    protected override void OnInitialized()
    {
        Refresh();
    }

    private void Refresh()
    {
        _customers = CustomerService.GetAll().ToList();
    }

    private void SaveCustomer()
    {
        _error = null;

        try
        {
            if (_isEditMode)
            {
                if (!CustomerService.Update(new Customer
                    {
                        Id = _editingId,
                        Name = _model.Name,
                        Email = _model.Email,
                        Phone = _model.Phone,
                        Address = _model.Address,
                    }))
                {
                    _error = "Unable to update customer.";
                    return;
                }
            }
            else
            {
                CustomerService.Add(new Customer
                {
                    Name = _model.Name,
                    Email = _model.Email,
                    Phone = _model.Phone,
                    Address = _model.Address,
                });
            }

            ResetForm();
            Refresh();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void BeginEdit(int id)
    {
        var customer = _customers.FirstOrDefault(c => c.Id == id);
        if (customer is null)
        {
            return;
        }

        _isEditMode = true;
        _editingId = customer.Id;
        _model = new Customer
        {
            Name = customer.Name,
            Email = customer.Email,
            Phone = customer.Phone,
            Address = customer.Address,
        };
    }

    private void CancelEdit()
    {
        ResetForm();
    }

    private void DeleteCustomer(int id)
    {
        _error = null;

        if (!CustomerService.Delete(id))
        {
            _error = "Unable to delete customer. Delete their invoices first.";
            return;
        }

        Refresh();
    }

    private void ResetForm()
    {
        _isEditMode = false;
        _editingId = 0;
        _model = new Customer();
    }
}
