@page "/"

<PageTitle>Invoice Generation System</PageTitle>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-3">📄 Invoice Generation System</h1>
            <p class="lead text-muted mb-4">
                Create, manage, and track professional invoices with ease.
            </p>
            <hr />
        </div>
    </div>

    <div class="row mt-4 g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h3>🧾 Invoices</h3>
                    <p class="card-text text-muted">Create and manage invoices. Track status from Draft to Paid.</p>
                    <a href="invoices" class="btn btn-primary">Go to Invoices</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h3>👥 Customers</h3>
                    <p class="card-text text-muted">Manage your customer list and their associated invoices.</p>
                    <a href="customers" class="btn btn-primary">Go to Customers</a>
                </div>
            </div>
        </div>
    </div>
</div>
